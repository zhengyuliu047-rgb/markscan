# Docker 部署可直接使用默认 PostgreSQL；生产环境建议修改 POSTGRES_PASSWORD。
POSTGRES_DB="markscan"
POSTGRES_USER="markscan"
POSTGRES_PASSWORD="change-this-password"
DATABASE_URL="postgresql://markscan:change-this-password@localhost:5432/markscan?schema=public"

# VPS 直接部署建议启用生产模式，并只监听本机，由 Nginx/Caddy 反代公网流量。
NODE_ENV="production"
HOST="127.0.0.1"
PORT="18888"

# 可选。未配置时系统会把持久化 AUTH_SECRET 写入数据库。
AUTH_SECRET="replace-with-64-hex-random-secret"

# 可选兼容项。新部署推荐首次访问 /setup 创建管理员。
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH=""

# 仅在单独运行 collector worker 时设为 "1"，避免 Web 内置采集器和 worker 重复采集。
MARKSCAN_DISABLE_EMBEDDED_COLLECTOR="0"

# 生产 HTTPS 建议保持 "1"。如果暂时只用 HTTP 反代测试登录，先设为 "0"。
MARKSCAN_COOKIE_SECURE="1"
